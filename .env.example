# Server Configuration
PORT=3000

# Google Sheets Configuration
# Publish your Google Sheet to the web as a CSV, and copy the CSV link here.
# Example: https://docs.google.com/spreadsheets/d/1xxxxxxxxx/pub?output=csv
GOOGLE_SHEET_CSV_URL=

# Cache Time-To-Live in milliseconds (default: 5 minutes)
CACHE_TTL_MS=300000
