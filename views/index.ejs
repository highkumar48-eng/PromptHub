<%- include('partials/header') %>

<section class="search-section">
  <h2 class="search-title">Enter Reel Keyword</h2>
  <form id="search-form" action="/search" method="GET" class="search-form">
    <div class="search-input-wrapper">
      <input 
        type="text" 
        id="search-keyword" 
        name="q" 
        class="search-input" 
        placeholder="Enter Keyword (Example: LIONKING)" 
        required 
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
      >
    </div>
    <button type="submit" class="search-btn">
      <span>Get Prompt</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
      </svg>
    </button>
  </form>
</section>

<!-- Ad Slot 1: Below Search Section -->
<%- include('partials/ad_slot', { slotId: 1 }) %>

<section class="how-it-works">
  <h3 class="section-title">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
      <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
      <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
    </svg>
    How It Works
  </h3>
  <div class="steps-list">
    <div class="step-card">
      <div class="step-number">1</div>
      <div class="step-text">Watch our Instagram <strong>Reel</strong></div>
    </div>
    <div class="step-card">
      <div class="step-number">2</div>
      <div class="step-text">Find the unique <strong>Keyword</strong> mentioned in the video</div>
    </div>
    <div class="step-card">
      <div class="step-number">3</div>
      <div class="step-text">Search the keyword on <strong>PromptHub</strong></div>
    </div>
    <div class="step-card">
      <div class="step-number">4</div>
      <div class="step-text"><strong>Copy the prompt</strong> instantly and generate your image</div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
