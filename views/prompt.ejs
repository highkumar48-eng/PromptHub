<%- include('partials/header') %>

<nav class="nav-breadcrumb">
  <a href="/" class="breadcrumb-link">Home</a>
  <span class="breadcrumb-separator">&rsaquo;</span>
  <a href="/browse" class="breadcrumb-link">Prompts</a>
  <span class="breadcrumb-separator">&rsaquo;</span>
  <span class="breadcrumb-current"><%= prompt.Keyword %></span>
</nav>

<article class="prompt-card">
  <header class="prompt-title-container">
    <span class="prompt-label">AI Image Prompt</span>
    <h2 class="prompt-page-title"><%= prompt.PromptTitle %></h2>
    <div class="prompt-meta-info">
      <span>Keyword: <strong><%= prompt.Keyword %></strong></span>
      <span>Published: <%= prompt.CreatedDate %></span>
      <span class="views-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
          <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.133 13.133 0 0 1 1.172 8z"/>
          <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z"/>
        </svg>
        Viewed <strong><%= prompt.Views %></strong> time<%= prompt.Views !== 1 ? 's' : '' %>
      </span>
    </div>
  </header>

  <% if (prompt.PreviewImageUrl && prompt.PreviewImageUrl.trim() !== '') { %>
    <div class="preview-image-container">
      <img src="<%= prompt.PreviewImageUrl %>" alt="<%= prompt.PromptTitle %> preview" class="preview-image" loading="lazy">
    </div>
  <% } %>

  <div class="prompt-box-wrapper">
    <textarea id="prompt-text" class="prompt-textarea" readonly><%= prompt.PromptText %></textarea>
  </div>

  <button id="copy-prompt-btn" class="copy-btn" aria-label="Copy prompt to clipboard">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
      <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1v-1z"/>
      <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5h3zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3z"/>
    </svg>
    <span>Copy Prompt</span>
  </button>

  <!-- FEATURE 4: Share Button -->
  <button id="share-btn" class="share-btn" aria-label="Share this prompt page">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
      <path d="M13.5 1a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM11 2.5a2.5 2.5 0 1 1 .603 1.628l-6.718 3.12a2.499 2.499 0 0 1 0 1.504l6.718 3.12a2.5 2.5 0 1 1-.488.876l-6.718-3.12a2.5 2.5 0 1 1 0-3.256l6.718-3.12A2.5 2.5 0 0 1 11 2.5zm-8.5 4a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm11 5.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3z"/>
    </svg>
    <span>Share</span>
  </button>
</article>

<!-- Ad Slot 2: Below Prompt Card -->
<%- include('partials/ad_slot', { slotId: 2, propellerZoneId: propellerZoneId }) %>

<%- include('partials/footer') %>
