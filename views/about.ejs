<%- include('partials/header') %>

<section class="static-page-card">
  <div class="static-page-header">
    <span class="prompt-label">About Us</span>
    <h2 class="static-page-title">What is PromptHub?</h2>
  </div>

  <div class="static-page-body">

    <div class="about-hero">
      <p class="about-lead">
        PromptHub is the <strong>fastest way to find AI image generation prompts</strong> from viral Instagram Reels — in under 10 seconds.
      </p>
    </div>

    <div class="policy-section">
      <h3 class="policy-heading">🎬 The Problem We Solve</h3>
      <p class="policy-text">
        You're scrolling Instagram and you see a breathtaking AI-generated image on a Reel. You think — <em>"I want to recreate this!"</em> — but you have no idea what prompt was used.
      </p>
      <p class="policy-text">
        Traditionally, you'd have to comment, DM the creator, search forums, or just give up. That's frustrating. <strong>PromptHub solves this.</strong>
      </p>
    </div>

    <div class="policy-section">
      <h3 class="policy-heading">✨ How It Works</h3>
      <div class="steps-list" style="margin-top: 0.75rem;">
        <div class="step-card">
          <div class="step-number">1</div>
          <div class="step-text">Watch our Instagram <strong>Reel</strong> — we showcase stunning AI-generated images</div>
        </div>
        <div class="step-card">
          <div class="step-number">2</div>
          <div class="step-text">Note the unique <strong>Keyword</strong> mentioned in the caption or video</div>
        </div>
        <div class="step-card">
          <div class="step-number">3</div>
          <div class="step-text">Type that keyword at <strong>PromptHub</strong> — it takes 2 seconds</div>
        </div>
        <div class="step-card">
          <div class="step-number">4</div>
          <div class="step-text"><strong>Copy the exact prompt</strong> and paste it into Midjourney, DALL-E, or any AI tool</div>
        </div>
      </div>
    </div>

    <div class="policy-section">
      <h3 class="policy-heading">🤖 Works With Any AI Tool</h3>
      <p class="policy-text">
        Our prompts are carefully crafted to work with popular AI image generation tools:
      </p>
      <div class="ai-tools-grid">
        <span class="ai-tool-badge">Midjourney</span>
        <span class="ai-tool-badge">DALL-E 3</span>
        <span class="ai-tool-badge">Stable Diffusion</span>
        <span class="ai-tool-badge">Adobe Firefly</span>
        <span class="ai-tool-badge">Ideogram</span>
        <span class="ai-tool-badge">Leonardo AI</span>
      </div>
    </div>

    <div class="policy-section">
      <h3 class="policy-heading">🆓 Completely Free</h3>
      <p class="policy-text">
        PromptHub is <strong>100% free to use</strong>. No account, no sign-up, no paywall. Just search and copy. We're supported by ads that keep the lights on.
      </p>
    </div>

    <div class="policy-section">
      <h3 class="policy-heading">📬 Get in Touch</h3>
      <p class="policy-text">
        Have a suggestion, want to collaborate, or found a bug? We'd love to hear from you.
      </p>
      <p class="policy-text">
        📧 <a href="mailto:hello@prompthub.com" class="policy-link">hello@prompthub.com</a>
      </p>
    </div>

  </div>

  <div class="static-page-footer-nav">
    <a href="/browse" class="search-btn" style="display:inline-flex; text-decoration:none; width:auto; padding: 0.875rem 1.5rem;">
      <span>Browse All Prompts</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
      </svg>
    </a>
    <a href="/" class="back-home-btn" style="margin-top: 0.75rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
      </svg>
      Back to Homepage
    </a>
  </div>
</section>

<%- include('partials/footer') %>
